{
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./**/node_modules/**)",
      "Read(./**/.next/**)",
      "Read(./**/dist/**)",
      "Read(./**/build/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "command": "npx prettier --write $CLAUDE_FILE_PATH"
      }
    ]
  }
}
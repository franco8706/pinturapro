# ── Simulador SAM (elegí UNA opción) ────────────────────────────────
# Opción A — Replicate (recomendada, sin infra propia):
#   1. Sacá tu token en https://replicate.com/account/api-tokens
#   2. Modelo: meta/sam-2 (segmenta la foto; el cliente elige la región del clic).
REPLICATE_API_TOKEN=
REPLICATE_VERSION=fe97b453a6455861e3bac769b441ca1f1086110da7466dbb65cf1eecfd60dc83
REPLICATE_POINTS_PER_SIDE=16        # densidad de muestreo: menos = más rápido, más = más fino
# Velocidad: para respuestas en ~2s creá un DEPLOYMENT con min_instances=1 (instancia tibia)
# en https://replicate.com/deployments y poné su nombre acá. Tiene prioridad sobre VERSION.
# REPLICATE_DEPLOYMENT=owner/name

# Opción B — Backend propio (FastAPI/SAM, etc.). Si está seteado, tiene prioridad.
# SAM_BACKEND_URL=
# SAM_BACKEND_TOKEN=

# Evaluación Nivel 3 (APIs de pago) — ver docs/simulador-apis.md
# BRIA_API_TOKEN=            # https://bria.ai — 1000 acciones gratis, para test-bria-wall.mjs

# ── Supabase (base de datos + auth + storage) ───────────────────────
# Crear proyecto en https://supabase.com → Project Settings → API.
#   URL y anon key: Settings → API. Service role: Settings → API (¡SECRETA, solo server!).
# Después correr supabase/migrations/0001_init.sql en el SQL Editor. Ver docs/supabase-setup.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Integraciones futuras (placeholders del roadmap) ────────────────
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_MAPBOX_TOKEN=
# RESEND_API_KEY=
